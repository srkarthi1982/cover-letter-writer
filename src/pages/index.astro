---
import AppShell from "../layouts/AppShell.astro";
import { AvContainer, AvButton } from "@ansiversa/components";

const title = "Cover Letter Writer — Ansiversa";
const description = "A premium manual workspace to draft, organize, and refine job-ready cover letters.";
---

<AppShell title={title} description={description}>
  <section class="border-b border-white/10 bg-gradient-to-b from-slate-950 to-slate-900 py-20">
    <AvContainer size="narrow">
      <p class="mb-4 text-xs uppercase tracking-[0.2em] text-emerald-300/80">Career writing workspace</p>
      <h1 class="text-4xl font-semibold text-white md:text-6xl">Write better cover letters with calm focus.</h1>
      <p class="mt-6 max-w-2xl text-lg text-slate-300">
        Keep every draft, refine each paragraph manually, and track your application-ready letters in one premium workspace.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <AvButton href="/app">Open workspace</AvButton>
        <AvButton href="https://ansiversa.com" variant="ghost">Explore Ansiversa</AvButton>
      </div>
    </AvContainer>
  </section>

  <section class="py-16">
    <AvContainer size="narrow">
      <div class="grid gap-6 md:grid-cols-3">
        <article class="rounded-2xl border border-white/10 bg-slate-900/60 p-6">
          <h2 class="text-lg font-medium text-white">Manual by design</h2>
          <p class="mt-3 text-sm text-slate-300">Compose every line yourself with thoughtful structure for intro, body, closing, and notes.</p>
        </article>
        <article class="rounded-2xl border border-white/10 bg-slate-900/60 p-6">
          <h2 class="text-lg font-medium text-white">Organized workflow</h2>
          <p class="mt-3 text-sm text-slate-300">Track drafts, ready letters, favorites, and archived history with fast search and clean filters.</p>
        </article>
        <article class="rounded-2xl border border-white/10 bg-slate-900/60 p-6">
          <h2 class="text-lg font-medium text-white">Built for focus</h2>
          <p class="mt-3 text-sm text-slate-300">A clutter-free workspace aligned with Ansiversa premium standards and professional tone.</p>
        </article>
      </div>
    </AvContainer>
  </section>
</AppShell>
